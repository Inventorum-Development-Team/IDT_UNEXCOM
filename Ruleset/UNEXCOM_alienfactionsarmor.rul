    specialWeapon: STR_VEHICLECRASH
  - type: PROBE_ARMOR
    heatVision: 50
    allowInv: false
    antiCamouflageAtDay: 40
    antiCamouflageAtDark: 30
    spriteInv: PROBE_INVENTORY.SPK
    spriteSheet: PROBE_SPRITESHEET.PCK
    scripts: # <- this node
      selectUnitSprite: |
        var int temp;
        var int walking;
        unit.isWalking walking;
        if eq walking 0;
          unit.getId temp;
          offsetmod temp 11 0 8; #desync animation of different units
          add temp anim_frame;
          wavegen_saw temp 8 8 7;
          mul sprite_offset 8;
          add sprite_offset 8;
          add sprite_offset temp;
          set sprite_index sprite_offset;
        else;
          add sprite_index sprite_offset;
        end;
        return sprite_index;
    corpseBattle:
      - STR_PROBE_CORPSE
    frontArmor: 15
    sideArmor: 10
    rearArmor: 10
    underArmor: 10
    drawingRoutine: 4
    constantAnimation: true
    damageModifier: *SoftAlienMechDamageModifier
    loftempsSet: [1]
  - type: CYBERSPHERE_ARMOR
    spriteInv: CYBERSPHERE_INVENTORY.SPK
    spriteSheet: CYBERSPHERE_SPRITESHEET.PCK
    deathFrames: 3
    heatVision: 50
    allowInv: false
    antiCamouflageAtDay: 40
    antiCamouflageAtDark: 30
    corpseBattle:
      - STR_CYBERSPHERE_CORPSE
    frontArmor: 10
    sideArmor: 10
    rearArmor: 10
    underArmor: 10
    drawingRoutine: 8
    movementType: 1
    size: 1
    damageModifier: *SoftAlienMechDamageModifier
    painImmune: true
    loftempsSet: [3]
    meleeDodge:
      reactions: 0.3
