  - type: MECHTOID_ARMOR
    spriteSheet: MECHTOID_SPRITESHEET.PCK
    heatVision: 50
    allowInv: true
    psiVision: 9
    antiCamouflageAtDay: 40
    antiCamouflageAtDark: 30
    spriteInv: MECHTOID_INVENTORY.SPK
    corpseBattle:
      - MECHTOID_CORPSE_1
      - MECHTOID_CORPSE_2
      - MECHTOID_CORPSE_3
