#BEGIN MEDIUM SCOUT
ufos:
####### Deleite This
  - type: STR_MEDIUM_SCOUT #ignoreDuplicate
    size: STR_SMALL
    sprite: 1
    damageMax: 250
    speedMax: 1200
    accel: 9
    power: 40
    range: 30
    score: 75
    reload: 15
    avoidBonus: 10
    shieldCapacity: 50
    shieldRechargeInGeoscape: 5
    shieldBleedThrough: 100
    breakOffTime: 250
    radarRange: 20
    radarChance: 30
    battlescapeTerrainData:
      name: IDT_UFOBASSAULTA1
      mapDataSets:
        - BLANKS
        - IDT_A1UFO_FLOOR
        - IDT_A1UFO_WALLS1
        - IDT_A1UFO_CLIMB1
        - IDT_A1UFO_RAMPS1
        - IDT_A1UFO_EXTWEAPONS1
        - IDT_A1UFO_DOORS1
        - IDT_A1UFO_TECHTIER1
