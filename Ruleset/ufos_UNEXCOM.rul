        - IDT_A1UFO_TECHTIER3
        - IDT_A1UFO_TECHTIER4
        - IDT_A1UFO_TECHTIER5
      mapBlocks:
        - name: IDT_UFOBASSAULTA1
          width: 10
          length: 10
        - name: IDT_UFOBASSAULTA2
          width: 10
          length: 10
        - name: IDT_UFOBASSAULTA3
          width: 10
          length: 10
        - name: IDT_UFOBASSAULTA4
          width: 10
          length: 10
        - name: IDT_UFOBASSAULTB1
          width: 10
          length: 10
