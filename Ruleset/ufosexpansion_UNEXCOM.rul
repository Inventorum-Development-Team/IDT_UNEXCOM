        - IDT_A1UFO_TECHTIER4
        - IDT_A1UFO_TECHTIER5
        - IDT_A1UFO_DIGITAL1
      mapBlocks:
        - name: CARRIERFILIP
          width: 50
          length: 30
          #items:
    #### Kiros UFO Carrier
  - type: STR_CARRIERKIRO
    size: STR_VERY_LARGE
    sprite: 6
    damageMax: 5000
