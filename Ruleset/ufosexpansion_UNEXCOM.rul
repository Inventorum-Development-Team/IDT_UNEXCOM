# spellchecker:words OPER ATURRET PTURRET SPTURRET
ufos:
  - type: STR_TROOP_LANDER #ignoreDuplicate
    battlescapeTerrainData:
      name: UFO_G0014
      mapDataSets:
        - BLANKS
        - U_EXT02
        - U_WALL02
        - U_PODS
        - U_BITS
        - U_OPER2
      mapBlocks:
        - name: UFO_G0014
          width: 30
          length: 20
          items:
            STR_ELERIUM_115:
              - [ 2, 3, 0]
              - [ 2, 6, 0]
              - [ 2, 13, 0]
              - [ 2, 16, 0]
              - [ 4, 3, 0]
              - [ 4, 6, 0]
              - [ 4, 13, 0]
              - [ 4, 16, 0]
            PTURRET_SPAWNER:
              - [ 2, 9, 2]
              - [ 26, 9, 2]
            ATURRET_SPAWNER:
              - [ 11, 17, 2]
              - [ 17, 17, 2]
              - [ 11, 1, 2]
              - [ 17, 1, 2]
            SPTURRET_SPAWNER:
              - [ 8, 8, 1]
              - [ 8, 11, 1]
              - [ 20, 8, 1]
              - [ 20, 11, 1]
          fuseTimers:
            PTURRET_SPAWNER: [0, 0]
            SPTURRET_SPAWNER: [0, 0]
            ATURRET_SPAWNER: [0, 0]
    #### Filips UFO Carrier
  - type: STR_CARRIERFILIP
    size: STR_VERY_LARGE
    sprite: 6
    damageMax: 3000
    speedMax: 1000
    shieldCapacity: 750
    shieldRechargeInGeoscape: 5
    shieldBleedThrough: 100
    accel: 2
    huntMode: 0
    huntSpeed: 100
    hunterKillerPercentage: 100
    power: 250
    powerBonus: 50
    missilePower: 5
    hitBonus: 40
    radarRange: 2000
    range: 2000
    score: 700
    reload: 30
    breakOffTime: 4000
    battlescapeTerrainData:
      name: CARRIERFILIP
      mapDataSets:
        - BLANKS
        - IDT_A1UFO_FLOOR
        - IDT_A1UFO_WALLS1
        - IDT_A1UFO_CLIMB1
        - IDT_A1UFO_RAMPS1
        - IDT_A1UFO_EXTWEAPONS1
